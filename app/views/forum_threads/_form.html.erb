<%= form_with(model: forum_thread) do |form| %>
  <% if forum_thread.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(forum_thread.errors.count, "error") %> prohibited this forum_thread from being saved:</h2>

      <ul>
        <% forum_thread.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :content, style: "display: block" %>
    <%= form.text_field :content %>
  </div>
  <br>
  <div>
    <%= form.label :forum_subforum_id, "Parent Subforum:" %><br>
    <%= form.collection_select :forum_subforum_id, ForumSubforum.all, :id, :name, prompt: "Select a Subforum" %>
  </div>
  <br>
  <div>
    <%= form.submit %>
  </div>
<% end %>
